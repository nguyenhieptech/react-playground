{
  "semi": true,
  "singleQuote": false,
  "arrowParens": "always",
  "bracketSpacing": true,
  "trailingComma": "es5",
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "tabWidth": 2,
  "printWidth": 90,
  "tailwindAttributes": [
    "enter",
    "enterFrom",
    "enterTo",
    "entered",
    "leave",
    "leaveFrom",
    "leaveTo"
  ],
  "tailwindFunctions": ["clsx", "cva"],
  "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "importOrderCaseInsensitive": true,
  "importOrderParserPlugins": ["typescript", "jsx"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "^react/(.*)$",
    "^next/(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^[@/].*",
    "^[./]",
    "^[../]"
  ]
}
